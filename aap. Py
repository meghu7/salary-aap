class SalaryCalculator:
    def __init__(self, email):
        self.email = email
        self.attendance_records = {}
        self.daily_rate = 500
        self.regular_hours_per_day = 8

    def log_attendance(self, date, status, day_name, overtime_hours=0):
        self.attendance_records[date] = {
            'status': status,
            'day': day_name,
            'overtime': overtime_hours
        }

    def calculate_monthly_salary(self):
        total_days_worked = 0
        total_overtime_pay = 0
        total_regular_overtime_hours = 0
        total_sunday_overtime_hours = 0
        sunday_pay = 0

        for date, record in self.attendance_records.items():
            status = record['status']
            day_name = record['day'].lower()
            overtime_hours = record['overtime']

            if day_name == 'sunday':
                total_sunday_overtime_hours += overtime_hours
                hourly_rate = self.daily_rate / self.regular_hours_per_day
                overtime_rate = hourly_rate * 2
                sunday_pay += overtime_hours * overtime_rate
                continue

            if status in ['green', 'yellow']:
                total_days_worked += 1
            elif status == 'pink':
                total_days_worked += 0.5
            
            if overtime_hours > 0:
                total_regular_overtime_hours += overtime_hours
                hourly_rate = self.daily_rate / self.regular_hours_per_day
                overtime_rate = hourly_rate * 2
                total_overtime_pay += overtime_hours * overtime_rate

        regular_pay = total_days_worked * self.daily_rate
        gross_pay = regular_pay + total_overtime_pay + sunday_pay
        
        pf_deduction = regular_pay * 0.12
        esic_deduction = regular_pay * 0.0075
        total_deductions = pf_deduction + esic_deduction
        
        net_pay = gross_pay - total_deductions
        return net_pay, regular_pay, total_overtime_pay, sunday_pay

class LoginScreen(BoxLayout):
    def __init__(self, **kwargs):
        super(LoginScreen, self).__init__(**kwargs)
        self.orientation = 'vertical'
        self.padding = 50
        self.spacing = 20
        
        self.add_widget(Label(text="Login", font_size=24))
        self.email_input = TextInput(hint_text="Email", multiline=False)
        self.add_widget(self.email_input)
        
        login_btn = Button(text="Submit")
        self.add_widget(login_btn)

